{
  "name": "Flutter Dev Container",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Dart-Code.flutter",
        "Dart-Code.dart-code",
        "eamodio.gitlens",
        "ms-vscode.vscode-json"
      ],
      "settings": {
        "dart.flutterSdkPath": "/opt/flutter",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.fixAll": "always"
        }
      }
    }
  },
  "remoteUser": "vscode"
}